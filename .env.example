# ── Required ─────────────────────────────────────────────
GEMINI_API_KEY=                  # Google Gemini — video scout, video analysis, cartoon, script (https://aistudio.google.com/apikey)
SERPER_API_KEY=                  # Serper — video search (https://serper.dev)
FAL_KEY=                         # fal.ai — Kling 2.5 Turbo Pro video generation (https://fal.ai/dashboard/keys)
ELEVENLABS_API_KEY=              # ElevenLabs — troll sound generation (https://elevenlabs.io)

# ── Optional (extra trend sources) ──────────────────────
PERPLEXITY_API_KEY=              # Perplexity — fallback trend detection (https://perplexity.ai)

# ── Optional (YouTube downloads) ───────────────────────
# YT_DLP_COOKIES=                # Path to cookies.txt (export from browser) — avoids "Sign in to confirm you're not a bot"
# YT_DLP_COOKIES_FROM_BROWSER=   # e.g. chrome or firefox — use browser cookies

# ── Optional (YouTube uploads) ─────────────────────────
# Upload is automatic once youtube_token.json exists (run setup_youtube_auth.py once).
# YOUTUBE_UPLOAD_ENABLED=       # Set to "false" to disable auto-upload
# YOUTUBE_ARBI_PLAYLIST_ID=     # Arbi playlist ID — every video is added to this playlist (get from playlist URL: youtube.com/playlist?list=PLxxxxxx)
